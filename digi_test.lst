....................  
.................... //------------------------------------------------------------------------------ 
.................... // Programming mode keys 
.................... //------------------------------------------------------------------------------ 
.................... #define key1       PIN_B3   // Increment / ON 
.................... #define key2       PIN_B2   // Decrement / OFF 
.................... #define ON         PIN_B4 
.................... #define OFF        PIN_B5 
....................  
.................... #define RLED       PIN_C0 
.................... #define YLED       PIN_C1 
.................... #define BLED       PIN_B1 
....................  
.................... // Rotary Encoder 
.................... #define ENCODER_A  PIN_C5 
.................... #define ENCODER_B  PIN_A4 
.................... #define ENCODER_SW PIN_B6 
....................  
.................... //------------------------------------------------------------------------------ 
.................... // GSM EEPROM base addresses 
.................... //------------------------------------------------------------------------------ 
.................... #define GSM_ENABLE_ADDR   0x61 
.................... #define NUM1_ADDR     0x62   // 10 bytes 
.................... #define NUM2_ADDR     0x6C   // 10 bytes 
.................... #define NUM3_ADDR     0x76   // 10 bytes 
.................... #define NUM4_ADDR     0x80   // 10 bytes 
.................... #define NUM5_ADDR     0x8A   // 10 bytes 
.................... #define GSM_SLOT_EN_ADDR  0x94   // 1 byte, bits 0-4 = slots 1-5 enabled 
.................... #define TIMER_MODE_ADDR   0x95 
.................... #define REPEAT_TIMER_ADDR  0x96   // add this near other #define addresses 
.................... #define TIMER_RESUME_H_ADDR    0x97 
.................... #define TIMER_RESUME_M_ADDR    0x98 
.................... #define TIMER_RESUME_S_ADDR    0x99 
.................... #define TIMER_RESUME_PHASE_ADDR 0x9A 
.................... #define TIMER_RESUME_SLOT_ADDR  0x9B 
.................... #define TIMER_RESUME_VALID_ADDR 0x9C   // 0xAA = valid save present 
.................... #define TIMER_HALT_VALID_ADDR   0x9D   // 0xBB = halted save present 
.................... #define TIMER_HALT_H_ADDR       0x9E 
.................... #define TIMER_HALT_M_ADDR       0x9F 
.................... #define TIMER_HALT_S_ADDR       0xA0 
.................... #define TIMER_HALT_PHASE_ADDR   0xA1 
.................... #define TIMER_HALT_SLOT_ADDR    0xA2 
