.................... int1 string_equals(char *str1, char *str2) { 
....................     int i = 0; 
....................     while(str1[i] != '\0' && str2[i] != '\0') { 
....................         if(str1[i] != str2[i]) 
....................             return 0; 
....................         i++; 
....................     } 
....................     if(str1[i] == '\0' && str2[i] == '\0') 
....................         return 1; 
....................     else 
....................         return 0; 
.................... } 
.................... /******************************************************************************* 
....................  * is_authorized - Check if sender is in stored numbers 
....................  *******************************************************************************/ 
.................... int1 is_authorized(char *sender) { 
....................     char temp[11]; 
....................     for(int slot = 1; slot <= 5; slot++) { 
....................         // Skip disabled slots (but always allow admin/slot1) 
....................         if(slot > 1 && slot_enabled[slot] == 0) { 
....................             continue; 
....................         } 
....................         
....................         read_number(slot, temp); 
....................         if(string_equals(sender, temp)) { 
....................             return 1; 
....................         } 
....................     } 
....................     return 0; 
.................... } 
