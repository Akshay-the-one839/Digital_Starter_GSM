.................... //============================================================================== 
.................... // Digital Motor Starter with GSM Integration 
.................... // Target  : PIC18F26K22 @ 20 MHz 
.................... // Compiler: CCS C 
.................... // 
.................... // GSM EEPROM Map (new additions): 
.................... //   0x61        = gsm_enable flag (0=disabled, 1=enabled) 
.................... //   0x62..0x6B  = Phone number slot 1 (10 digits) 
.................... //   0x6C..0x75  = Phone number slot 2 (10 digits) 
.................... //   0x76..0x7F  = Phone number slot 3 (10 digits) 
.................... //   0x80..0x89  = Phone number slot 4 (10 digits) 
.................... //   0x8A..0x93  = Phone number slot 5 (10 digits) 
.................... //   0x94        = Slot enable flags (bits 0-4 for slots 1-5) 
.................... // 
.................... // GSM UART: TX=PIN_C6, RX=PIN_C7 @ 9600 baud 
.................... //============================================================================== 
....................  
.................... //LCD module connections 
.................... #define LCD_DATA_PIN  PIN_C3 
.................... #define LCD_CLOCK_PIN PIN_C4 
.................... #define LCD_EN_PIN    PIN_B0 
.................... //End LCD module connections 
....................  
