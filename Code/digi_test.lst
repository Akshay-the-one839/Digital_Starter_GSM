.................... //============================================================================== 
.................... // Send detailed status to a specific phone number 
.................... //============================================================================== 
.................... void send_detailed_status_to_number(char *num) { 
....................     char status_msg[120]; 
....................     disable_interrupts(int_AD); 
....................     disable_interrupts(int_TIMER1); 
....................     format_detailed_status(status_msg); 
....................     send_sms_to_number(num, status_msg); 
....................       enable_interrupts(int_AD); 
....................        enable_interrupts(int_TIMER1); 
....................         enable_interrupts(GLOBAL); 
.................... } 
