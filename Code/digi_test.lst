.................... void send_led_change_all(int1 state) { 
....................    if(state) strcpy(msg_buffer, LED_ON_MSG); 
....................    else strcpy(msg_buffer, LED_OFF_MSG); 
....................     disable_interrupts(int_AD); 
....................             disable_interrupts(int_TIMER1); 
....................    send_sms_to_all_enabled(msg_buffer); 
....................      enable_interrupts(int_AD); 
....................                   enable_interrupts(int_TIMER1); 
....................                   enable_interrupts(GLOBAL); 
.................... } 
.................... void send_led_status_all() { 
