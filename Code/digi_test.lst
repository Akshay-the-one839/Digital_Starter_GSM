.................... int1 two_phase_ok(void) 
.................... { 
....................     if(phase_setting == 0)  // 2P mode only 
....................     { 
....................         if(vr < 50 || vy < 50) 
....................             return 0;  // R or Y missing - block motor 
....................     } 
....................     return 1;  // 3P mode handled elsewhere, or both R+Y present 
.................... } 
