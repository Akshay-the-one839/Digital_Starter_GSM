   delay_ms(10);
   read_adc(ADC_START_ONLY);
   enable_interrupts(GLOBAL);

   //--------------------------------------------------------------------------
   // Phase sequence detection (unchanged)
   //--------------------------------------------------------------------------
   if(seqok==0)
   {
      while(1)
      {
         output_low(RLED); output_low(YLED); output_low(BLED);
         delay_ms(300);
         output_high(RLED); output_high(YLED); output_high(BLED);
         delay_ms(200);
         display_sequence(); reset_sequence();
         if(ryb_detected>=5){ wait=1; break; }
         new_value(); voltage();
         currentr=0; currentr2=0; currentr3=0;
         if(sentflg==1||sentflg2==1){ sentflg=0; sentflg2=0; }
      }
   }
   if(seqok==1)
   {
      while(1)
      {
         output_low(RLED); output_low(YLED); output_low(BLED);
         delay_ms(300);
         output_high(RLED); output_high(YLED); output_high(BLED);
         delay_ms(200);
         seq_flag=1; reset_sequence(); ryb_detected++;
         if(ryb_detected>=5){ wait=1; break; }
         new_value(); voltage();
         currentr=0; currentr2=0; currentr3=0;
         if(sentflg==1||sentflg2==1){ sentflg=0; sentflg2=0; }
      }
   }
   output_low(RLED); output_low(YLED); output_low(BLED);

   prog=0; menu_number=1; in_menu_selection=1;
   int8 ct_ratio = read_eeprom(0x60);

   //--------------------------------------------------------------------------
   // GSM init on startup if flag is set
   //--------------------------------------------------------------------------
   if(gsm_enable==1)
   {
      disable_interrupts(int_AD);
      disable_interrupts(int_TIMER1);
      gsm_init();
      enable_interrupts(INT_RDA);   // start listening for GSM commands
      enable_interrupts(int_AD);
      enable_interrupts(int_TIMER1);
      enable_interrupts(GLOBAL);
   }

   //--------------------------------------------------------------------------
   // Power-on delay countdown (unchanged)
   //--------------------------------------------------------------------------
   disable_interrupts(int_AD);
   disable_interrupts(int_TIMER1);
   lcd_cmd(LCD_CLEAR);
   while(1)
   {
      delay_time1--;
      lcd_goto(1,1); printf(lcd_out,"POWER ON DLY...");
      lcd_goto(1,2); printf(lcd_out,"   %ld sec   ",(long)delay_time1);
      delay_ms(950);
      if(delay_time1<=1) break;
   }
   delay_ms(100);
   enable_interrupts(int_AD);
   enable_interrupts(int_TIMER1);
   enable_interrupts(GLOBAL);
   lcd_cmd(LCD_CLEAR);

   //--------------------------------------------------------------------------
   // Main loop
   //--------------------------------------------------------------------------
   while(1)
   {
   // ---- TIMER MODE ----
      if(timer_mode == 1)
         handle_timer_mode();
      else
      {
         if(timer_running == 1)
         {
            timer_running = 0;
            timer_phase_done = 0;
         }
      }
      new_value();
      voltage();
      amps();
      if(volt_level != 0 || amps_level != 0) {
          if(on_state == 1) {
              moff();
              on_state = 0;
          }
      }

      if(t_state==on_state) now=now;
      else { t_state=on_state; now=2; }
      new_value();

      for(i=0;i<1;i++)
      {
         if(old_value[i]==voltages[i] && temp_amp==currentr)
            now=(now==0)?0:now;
         else
         { old_value[i]=voltages[i]; temp_amp=currentr; now=(now==0)?1:now; }
      }
   
      rvolt=(int16)vr1; yvolt=(int16)vy1; bvolt=(int16)vb1;
      rvolt3=((rvolt/100)%10); rvolt2=((rvolt/10)%10); rvolt1=(rvolt%10);
      yvolt3=((yvolt/100)%10); yvolt2=((yvolt/10)%10); yvolt1=(yvolt%10);
      bvolt3=((bvolt/100)%10); bvolt2=((bvolt/10)%10); bvolt1=(bvolt%10);
     
             if(timer_mode == 0)
         {
             // MANUAL mode display - show voltage and current
             lcd_goto(1,1); printf(lcd_out,"%2.0f",currentr);
             lcd_goto(5,1); printf(lcd_out,"%2.0f",currentr2);
             lcd_goto(9,1); printf(lcd_out,"%2.0f",currentr3);
             lcd_goto(14,1);
             if(phase_setting==0) printf(lcd_out,"2P");
              if(phase_setting==1)  printf(lcd_out,"3P");
             lcd_goto(14,2); 
             if( on_state == 1)printf(lcd_out,"ON ");              
             if( on_state == 0)printf(lcd_out,"OFF");
             lcd_goto(1,2); printf(lcd_out,"%d%d%d,",rvolt3,rvolt2,rvolt1);
             lcd_goto(5,2); printf(lcd_out,"%d%d%d,",yvolt3,yvolt2,yvolt1);
             lcd_goto(9,2); printf(lcd_out,"%d%d%d", bvolt3,bvolt2,bvolt1);
            
        
              
        
         }
         else if(timer_mode == 1)
         {
             // TIMER mode - normal display (showing currents/voltages)
             lcd_goto(1,1); printf(lcd_out,"%2.0f",currentr);
             lcd_goto(5,1); printf(lcd_out,"%2.0f",currentr2);
             lcd_goto(9,1); printf(lcd_out,"%2.0f",currentr3);
             lcd_goto(14,1);
             if(phase_setting==0) printf(lcd_out,"2P");
             if(phase_setting==1)printf(lcd_out,"3P");  
             lcd_goto(14,2); 
          //   if( on_state == 1)printf(lcd_out,"ON ");              
          //   if( on_state == 0)printf(lcd_out,"OFF");    
             lcd_goto(1,2); printf(lcd_out,"%d%d%d,",rvolt3,rvolt2,rvolt1);
             lcd_goto(5,2); printf(lcd_out,"%d%d%d,",yvolt3,yvolt2,yvolt1);
             lcd_goto(9,2); printf(lcd_out,"%d%d%d", bvolt3,bvolt2,bvolt1);
             
             
           
              
          
             // KEY1 pressed - show detailed timer info (safe, non-blocking)
         if(!input(key1))
         {
             delay_ms(50);  // Debounce
             if(!input(key1))
             {
                 // Disable interrupts BEFORE reading timer values
                
                disable_interrupts(int_TIMER1);
               disable_interrupts(GLOBAL);
                 int8 disp_h = timer_h;
                 int8 disp_m = timer_m;
                 int8 disp_s = timer_s;
                 int8 disp_phase = timer_phase;
         
               
         
                 lcd_cmd(LCD_CLEAR);

              lcd_goto(1,1);

               if(ctimer == 1)
               {
                  printf(lcd_out,"Timer %d", active_timer_slot+1);
                  lcd_goto(1,2);
                  printf(lcd_out,"%02d:%02d:%02d   ",
                  disp_h, disp_m, disp_s);
                  lcd_goto(14,2); printf(lcd_out,"ON ");
                   delay_ms(3000);    
                   
               }
               if(ctimer == 0)
               {
                   printf(lcd_out,"Timer %d", active_timer_slot+1);
                   lcd_goto(1,2);
                  printf(lcd_out,"%02d:%02d:%02d   ",
                  disp_h, disp_m, disp_s);
                  lcd_goto(14,2); printf(lcd_out,"OFF");
                   delay_ms(3000);  
               }
                      
                      //(disp_phase==0) ? "ON" : "OFF");
               
                enable_interrupts(int_TIMER1);
                enable_interrupts(GLOBAL);
                 // Wait for key release
               //  while(!input(key1));
                
         
                 lcd_cmd(LCD_CLEAR);
             }
         }
         }

      // ---- GSM command processing (only when enabled) ----
     if(gsm_enable==1 && RX_Command_Ready==1) {
            RX_Command_Ready = 0;
             disable_interrupts(int_AD);
             disable_interrupts(int_TIMER1);
            extract_sender_simple(RxBuffer, sender);
             enable_interrupts(int_AD);
                  enable_interrupts(int_TIMER1);
                  enable_interrupts(GLOBAL);
         
            if(RxBuffer[0]=='#' && (RxBuffer[1]=='E' || RxBuffer[1]=='D'))
            {
               disable_interrupts(int_AD);
              disable_interrupts(int_TIMER1);
               process_enable_disable(RxBuffer, sender);
                enable_interrupts(int_AD);
                  enable_interrupts(int_TIMER1);
                  enable_interrupts(GLOBAL);
            }
         
            if(RxBuffer[0]=='#' && RxBuffer[1]=='O' && RxBuffer[2]=='N') {
               // motor ON
               if(volt_level==0 && amps_level==0 && timer_mode==0) {
                  disable_interrupts(int_AD);
                  disable_interrupts(int_TIMER1);
                   lcd_goto(14,2); printf(lcd_out,"ON ");
                  mon(); on_state=1; state=1; q='A';                
                  strcpy(msg_buffer, LED_ON_MSG);
                  send_sms_to_all_enabled(msg_buffer);
                   enable_interrupts(int_AD);
                  enable_interrupts(int_TIMER1);
                  enable_interrupts(GLOBAL);
               }
            }
            else if(timer_mode==0 && RxBuffer[0]=='#' && RxBuffer[1]=='O' && RxBuffer[2]=='F') {
               disable_interrupts(int_AD);
               disable_interrupts(int_TIMER1);
                lcd_goto(14,2); printf(lcd_out,"OFF");
               moff(); on_state=0; state=0; q='a';              
               strcpy(msg_buffer, LED_OFF_MSG);
               send_sms_to_all_enabled(msg_buffer);
               enable_interrupts(int_AD);
               enable_interrupts(int_TIMER1);
               enable_interrupts(GLOBAL);
            }
            else if(RxBuffer[0]=='$' && RxBuffer[1]=='S') {
                   // Check if sender is authorized (admin only or all enabled?)
                   // Option A: Send to all enabled numbers
                   disable_interrupts(int_AD);
                  disable_interrupts(int_TIMER1);
                   send_detailed_status_to_all();
                    enable_interrupts(int_AD);
                  enable_interrupts(int_TIMER1);
                  enable_interrupts(GLOBAL);
                   
                   // Option B: Send only to the requesting sender (uncomment below, comment above)
                   // if(strlen(sender) > 0) {
                   //     char detailed_status[120];
                   //     format_detailed_status(detailed_status);
                   //     send_sms_to_number(sender, detailed_status);
                   // }
               }
            else if(RxBuffer[0]=='?' && RxBuffer[1]=='N') {
            disable_interrupts(int_AD);
                  disable_interrupts(int_TIMER1);
               send_all_numbers(num1);
                enable_interrupts(int_AD);
                  enable_interrupts(int_TIMER1);
                  enable_interrupts(GLOBAL);
            }
           // === SAVE NUMBER (#n[slot] [number]) ===
            else if(RxBuffer[0]=='#' && RxBuffer[1]=='n') {
                char debug_msg[64];
                char temp_num[11];
                int i = 2;
                 lcd_cmd(LCD_CLEAR);
                lcd_goto(1,2);
                // Skip any spaces after '#n'
                while(RxBuffer[i] == ' ') i++;
               
                // Get slot number
                if(!isdigit(RxBuffer[i])) {
                     sprintf(debug_msg, "Invalid format: #n<slot><10digit number>");
                        disable_interrupts(int_AD);
                  disable_interrupts(int_TIMER1);
                    send_sms_to_number(num1, debug_msg);
                 enable_interrupts(int_AD);
                  enable_interrupts(int_TIMER1);
                  enable_interrupts(GLOBAL);
                    memset(RxBuffer, 0, sizeof(RxBuffer));
                    continue;
                }
                slot = RxBuffer[i] - '0';
                i++;
               
                // Skip any spaces after slot
                while(RxBuffer[i] == ' ') i++;
               
                // Extract exactly 10 digits for phone number
                int k = 0;
                while(RxBuffer[i] != '\0' && k < 10 && isdigit(RxBuffer[i])) {
                    temp_num[k] = RxBuffer[i];
                   
                     printf(lcd_out,"%c",temp_num[k]);
                     k++;
                     i++;
                }
                temp_num[k] = '\0';
               
                // Validate we got 10 digits
                if(k != 10) {
                    sprintf(debug_msg, "Error: Need 10 digits, got %d", k);
                     disable_interrupts(int_AD);
                  disable_interrupts(int_TIMER1);
                    send_sms_to_number(num1, debug_msg);
                     enable_interrupts(int_AD);
                  enable_interrupts(int_TIMER1);
                  enable_interrupts(GLOBAL);
                    memset(RxBuffer, 0, sizeof(RxBuffer));
                    continue;
                }
               
                // Validate slot range
                if(slot < 1 || slot > 5) {
                 disable_interrupts(int_AD);
                  disable_interrupts(int_TIMER1);
                    send_sms_to_number(num1, (char *)"Invalid slot number (1-5)");
                     enable_interrupts(int_AD);
                  enable_interrupts(int_TIMER1);
                  enable_interrupts(GLOBAL);
                }
                else if(slot == 1) {
                    // Check if admin already exists (optional)
                    char existing_admin[11];
                    read_number(1, existing_admin);
                    if(existing_admin[0] != '\0' && existing_admin[0] != 0xFF) {
                     disable_interrupts(int_AD);
                  disable_interrupts(int_TIMER1);
                        send_sms_to_number(num1, ADMIN_EXISTS_MSG);
                         enable_interrupts(int_AD);
                  enable_interrupts(int_TIMER1);
                  enable_interrupts(GLOBAL);
                    } else {
                       
                         disable_interrupts(int_AD);
                  disable_interrupts(int_TIMER1);
                  save_number(temp_num, 1);
                        send_sms_to_number(num1, ADMIN_SAVED_MSG);
                         enable_interrupts(int_AD);
                  enable_interrupts(int_TIMER1);
                  enable_interrupts(GLOBAL);
                    }
                }
                else {
                disable_interrupts(int_AD);
                  disable_interrupts(int_TIMER1);
                    save_number(temp_num, slot);
                    char confirm_msg[50];
                    sprintf(confirm_msg, "Number saved to slot %d", slot);
                    send_sms_to_number(num1, confirm_msg);
                     enable_interrupts(int_AD);
                  enable_interrupts(int_TIMER1);
                  enable_interrupts(GLOBAL);
                }
            }
         
            memset(RxBuffer, 0, sizeof(RxBuffer));
         }

      // ---- Enter menu (ENCODER_SW + KEY2 together) ----
      if(prog==0)
      {
         if(!input(ENCODER_SW) && !input(key2))
         {
            delay_ms(30);
            if(!input(ENCODER_SW) && !input(key2))
            {
               disable_interrupts(int_AD);
               disable_interrupts(int_TIMER1);
               lcd_cmd(LCD_CLEAR); lcd_goto(1,1); printf(lcd_out,"ENTERING MENU...");
               delay_ms(2000); lcd_cmd(LCD_CLEAR);
               while(!input(ENCODER_SW)||!input(key2));
               while(input(ENCODER_SW)==0); delay_ms(1000);
               prog=1; in_menu_selection=1; menu_number=1;
            }
         }
      }
      else if(prog==1)
      {
         disable_interrupts(int_AD);
         disable_interrupts(int_TIMER1);
         lcd_cmd(LCD_CLEAR);
         handle_menu();
         // Restore GSM RDA interrupt after menu exits if GSM enabled
         if(gsm_enable==1) enable_interrupts(INT_RDA);
         enable_interrupts(int_AD);
         enable_interrupts(int_TIMER1);
         enable_interrupts(GLOBAL);
      }

 
     // ---- KEY1 : Motor ON ----
      if(timer_mode==0 && !input(key1) && volt_level==0 && amps_level==0)
      {
         disable_interrupts(int_AD);
         disable_interrupts(int_TIMER1);
         lcd_goto(14,2); printf(lcd_out,"ON ");
         mon(); q='A'; state=1; on_state=1; setsw=1; ckflg=1;
         
        // if(gsm_enable==1) gsm_send_to_all("MOTOR ON (LOCAL)");
         enable_interrupts(int_AD);
         enable_interrupts(int_TIMER1);
         enable_interrupts(GLOBAL);
      }

   
      // ---- KEY2 : Motor OFF ----
      if(timer_mode==0 && !input(key2))
      {
         disable_interrupts(int_AD);
         disable_interrupts(int_TIMER1);
         lcd_goto(14,2); printf(lcd_out,"OFF");
         moff(); setsw=1; on_state=0; q='a'; state=0; auto_state=1;
       
       //  if(gsm_enable==1) gsm_send_to_all("MOTOR OFF (LOCAL)");
         enable_interrupts(int_AD);
         enable_interrupts(int_TIMER1);
         enable_interrupts(GLOBAL);
      }
   } // while(1)
