//==============================================================================
// ADC INTERRUPT (unchanged)
//==============================================================================
#int_AD
void adc_isr()
{
   int16 adc_sample = read_adc(ADC_READ_ONLY);
   if(channel <= 2 && adc_sample > adc_values[channel])
      adc_values[channel] = adc_sample;
   else if(channel > 2 && adc_sample < adc_values[channel])
      adc_values[channel] = adc_sample;

   if(channel <= 2 && (last_val[channel] > THRESHOLD) && (adc_sample <= THRESHOLD))
   {
      if(!crossed[channel])
      {
         crossed[channel] = 1;
         if(seq_index < 3)
            sequence[seq_index++] = channel;
      }
   }
   if(channel <= 2)
      last_val[channel] = adc_sample;

   if(wait == 0)
   {
      switch(channel)
      {
         case 0: channel=1; break;
         case 1: channel=2; break;
         case 2: channel=0; break;
      }
   }
   else
   {
      switch(channel)
      {
         case 0: channel=1; break;
         case 1: channel=2; break;
         case 2: channel=3; break;
         case 3: channel=4; break;
         case 4: channel=5; break;
         case 5: channel=0; break;
      }
   }

   if(channel == 5)
      set_adc_channel(14);
   else
      set_adc_channel(channel);

   read_adc(ADC_START_ONLY);
}

//==============================================================================
// TIMER1 INTERRUPT (unchanged)
//==============================================================================
#int_TIMER1
void timer1_isr()
{
   sec_counter++;
   if(h_time != 0 || m_time != 0 || s_time != 0)
   {
      time_en++;
      if(time_en >= 20)
      {
         time_en = 0;
         if(s_time > 0)
            s_time--;
         else
         {
            s_time = 59;
            if(m_time > 0)
               m_time--;
            else
            {
               m_time = 59;
               if(h_time > 0)
                  h_time--;
               else { time_h=0; time_m=0; time_s=0; }
            }
         }
      }
   }

   time_en2++;
   if(time_en2 >= 20)
   {
      time_en2 = 0;
      if(dly < 59) dly++;
   }

   if(dry_s != 0) dry_s++;
   if(auto_state == 0 && aut == 1) auto_start_s++;
   if(dry_reset_s != 0) dry_reset_s++;

   // ---- TIMER MODE countdown ----
 
      if(timer_mode==1 && timer_running==1)
      {
          t_en++;
          if(t_en >= 20)  // 1 second elapsed
          {
              t_en = 0;
              
              // Check if timer already expired
              if(timer_h == 0 && timer_m == 0 && timer_s == 0)
              {
                  timer_phase_done = 1;
              //    timer_running = 0;
              }
              else
              {
                  // Decrement time
                  if(timer_s > 0)
                      timer_s--;
                  else
                  {
                      timer_s = 59;
                      if(timer_m > 0)
                          timer_m--;
                      else
                      {
                          timer_m = 59;
                          if(timer_h > 0)
                              timer_h--;
                      }
                  }
              }
          }
      }

   if(sec_counter >= 10*5)
   {
      update_flag = 1;
      sec_counter = 0;
   }
   if(dry_s > drys*10)
      amps_level = 1;
   if(auto_start_s >= 60*10 && auto_state == 0)
   {
      if(aut == 1) { state=1; auto_state=1; auto_start_s=0; }
   }
   if(dry_reset_s > (unsigned long)dry_restart_val * 15)
      amps_level = 0;

   set_timer1(34286);
}
//==============================================================================
// UART RDA INTERRUPT
// Handles GSM incoming data when gsm_enable==1
// Original code had no RDA ISR active in normal operation; added safely.
//==============================================================================
#int_RDA
void RDA_isr(void) {
   char temp;
   static int collecting = 0;

   if(!gsm_enable) return;
   
   temp = getc(GSM);

   // If a new command start is seen, begin collecting into RxBuffer
   if(temp == '#' || temp == '?' || temp == '$' || temp == '@') {
      Index = 0;
      collecting = 1;
      RxBuffer[Index++] = temp;
      return;
   }

   // If we are collecting a command, accumulate until CR/LF (end)
   if(collecting) {
      if(temp == '\r' || temp == '\n') {
         RxBuffer[Index] = '\0';
         RX_Command_Ready = 1;  // signal main loop to process the command
         collecting = 0;
      }
      else if(Index < sizeof(RxBuffer)-1) {
         RxBuffer[Index++] = temp;
      }
   }
}

//==============================================================================
// Format detailed status message for SMS
//==============================================================================
void format_detailed_status(char *output_msg) {
    int16 vr_val, vy_val, vb_val;
    int16 cr_int, cy_int, cb_int;
   
    // Get current voltage values
    vr_val = voltages[0];
    vy_val = voltages[1];
    vb_val = voltages[2];
   
    // Convert current to fixed-point (multiply by 10 for 1 decimal)
    cr_int = (int16)(currents[0] * 10);
    cy_int = (int16)(currents[1] * 10);
    cb_int = (int16)(currents[2] * 10);
   
    // Clear output message
    output_msg[0] = '\0';
   
    // Add status line
    if(on_state == 1) {
        strcat(output_msg, STATUS_ON_MSG);
    } else {
        strcat(output_msg, STATUS_OFF_MSG);
    }
     
     char newline[] = "\r\n";
     strcat(output_msg, newline);
    // Add voltage line
    char volt_str[40];
    sprintf(volt_str, "Voltage R: %lu V, Y: %lu V, B: %lu V\r\n",
            (unsigned long)vr_val, (unsigned long)vy_val, (unsigned long)vb_val);
    strcat(output_msg, volt_str);
   
    // Add current line
    char curr_str[50];
    sprintf(curr_str, "Current R: %lu.%lu A, Y: %lu.%lu A, B: %lu.%lu A",
            (unsigned long)(cr_int/10), (unsigned long)((cr_int%10 < 0) ? -(cr_int%10) : (cr_int%10)),
            (unsigned long)(cy_int/10), (unsigned long)((cy_int%10 < 0) ? -(cy_int%10) : (cy_int%10)),
            (unsigned long)(cb_int/10), (unsigned long)((cb_int%10 < 0) ? -(cb_int%10) : (cb_int%10)));
    strcat(output_msg, curr_str);
}
//==============================================================================
// Send detailed status to a specific phone number
//==============================================================================
void send_detailed_status_to_number(char *num) {
    char status_msg[120];
    disable_interrupts(int_AD);
    disable_interrupts(int_TIMER1);
    format_detailed_status(status_msg);
    send_sms_to_number(num, status_msg);
      enable_interrupts(int_AD);
       enable_interrupts(int_TIMER1);
        enable_interrupts(GLOBAL);
}

//==============================================================================
// Send detailed status to all enabled phone numbers
//==============================================================================
void send_detailed_status_to_all(void) {
    char status_msg[150];
    format_detailed_status(status_msg);
   
    for(int slot = 1; slot <= 5; slot++) {
        if(slot_enabled[slot] == 1) {
            read_number(slot, number);
            if(number[0] != '\0' && number[0] != 0xFF) {
            disable_interrupts(int_AD);
             disable_interrupts(int_TIMER1);
                send_sms_to_number(number, status_msg);
                  enable_interrupts(int_AD);
                  enable_interrupts(int_TIMER1);
                  enable_interrupts(GLOBAL);
            }
        }
    }
}
void send_sms_to_number(char *num, char *msg) {
   fprintf(GSM,"\r\n");
   delay_ms(500);
   // use international +91 because numbers are stored as 10 digits
   fprintf(GSM,"AT+CMGS=\"+91%s\"\r", num);
   delay_ms(1000);
   fprintf(GSM,"%s\r\n", msg);
   putc(0x1A, GSM);   // CTRL+Z to finish SMS body
   delay_ms(7000);    // wait for send completion (original code used long delays)
   lcd_cmd(LCD_CLEAR);
}

void save_number(char *num, int slot) {
   int base_addr;
   if(slot==1) base_addr=NUM1_ADDR;
   else if(slot==2) base_addr=NUM2_ADDR;
   else if(slot==3) base_addr=NUM3_ADDR;
   else if(slot==4) base_addr=NUM4_ADDR;
   else if(slot==5) base_addr=NUM5_ADDR;
   else return;

   // write 10 bytes (digits) to EEPROM
   for(int i=0;i<10;i++)
      write_eeprom(base_addr+i,num[i]);

   // reload runtime buffers from EEPROM (keeps num1..num4 consistent)
   lcd_cmd(LCD_CLEAR);
   lcd_goto(2,1);
   for(int j=0; j<10; j++){
      num1[j] = read_eeprom(NUM1_ADDR + j);
       
        printf(lcd_out,"%c",num1[j] );                                     /////////////////////////////
   }
   num1[10] = '\0';
   
    lcd_goto(2,1);
   for(int y=0; y<10; y++){
      num2[y] = read_eeprom(NUM2_ADDR + y);
      printf(lcd_out,"%c",num2[y] );  
   }
   num2[10] = '\0';
   
   lcd_goto(2,1);
   for(int x=0; x<10; x++){
      num3[x] = read_eeprom(NUM3_ADDR + x);
      printf(lcd_out,"%c",num3[x] );  
   }
   num3[10] = '\0';
   
   lcd_goto(2,1);
   for(int z=0; z<10; z++){
      num4[z] = read_eeprom(NUM4_ADDR + z);
      printf(lcd_out,"%c",num4[z] );  
   }
   num4[10] = '\0';
   
    lcd_goto(2,1);
   for(int w=0; w<10; w++){
    num5[w] = read_eeprom(NUM5_ADDR + w);
    printf(lcd_out,"%c",num5[w] );
   }
   num5[10] = '\0';
}
void init_slot_status(void) {
    int8 slot_flags = read_eeprom(GSM_SLOT_EN_ADDR);
   
    // Slot 1 (admin) is ALWAYS enabled - ignore EEPROM for slot 1
    slot_enabled[1] = 1;
   
    // For slots 2-5, read from EEPROM
    for(int i = 2; i <= 5; i++) {
        // Read bit (i-1) from slot_flags
        slot_enabled[i] = (slot_flags >> (i-1)) & 1;
       
        // If EEPROM was 0xFF (uninitialized), default to 1
        if(slot_flags == 0xFF) {
            slot_enabled[i] = 1;
        }
    }
   
    // If uninitialized, save default values (all slots 2-5 enabled)
    if(slot_flags == 0xFF) {
        int8 default_flags = 0x1E;  // Bits 1-4 set (slots 2-5 enabled)
        write_eeprom(GSM_SLOT_EN_ADDR, default_flags);
    }
}

/*******************************************************************************
 * extract_sender_simple - Extract phone number from GSM notification
 * Handles format: +CMGR: "REC READ","+919600919533",...
 *******************************************************************************/
void extract_sender_simple(char *rx, char *sender) {
    int i = 0, j = 0;
    int quote_count = 0;
   
    // Clear sender buffer
    sender[0] = '\0';
   
    // Find the second quote pair (where the phone number is)
    while(rx[i] != '\0' && j < 10) {
        if(rx[i] == '"') {
            quote_count++;
            i++;
            continue;
        }
       
        // Phone number is between 2nd and 3rd quote
        if(quote_count == 2) {
            // Skip any '+' or country code if present
            if(rx[i] == '+' || rx[i] == '9' && j == 0) {
                // Skip + and first digit if it's country code
                i++;
                continue;
            }
            if(isdigit(rx[i])) {
                sender[j++] = rx[i];
            }
        }
        i++;
    }
    sender[j] = '\0';
   
    // If we got nothing, try simple method
    if(j == 0) {
        i = 0; j = 0; quote_count = 0;
        while(rx[i] != '\0' && j < 10) {
            if(rx[i] == '"') quote_count++;
            else if(quote_count == 1) sender[j++] = rx[i];
            i++;
        }
        sender[j] = '\0';
    }
}
void save_slot_enable_status(int slot, int status) {
    if(slot < 2 || slot > 5) {
        // Admin or invalid slot - cannot disable
        return;
    }
   
    slot_enabled[slot] = status;
   
    // Read current slot flags
    int8 slot_flags = read_eeprom(GSM_SLOT_EN_ADDR);
    if(slot_flags == 0xFF) slot_flags = 0x1E;  // Default: slots 2-5 enabled
   
    // Update the bit for this slot (bits 0-4 for slots 1-5)
    if(status == 1) {
        slot_flags |= (1 << (slot-1));   // Set bit
    } else {
        slot_flags &= ~(1 << (slot-1));  // Clear bit
    }
   
    // Save back to EEPROM
    write_eeprom(GSM_SLOT_EN_ADDR, slot_flags);
}
void process_enable_disable(char *rx, char *sender) {
    int slot = rx[4] - '0';
    char reply[32];

    // LCD debug
    lcd_cmd(LCD_CLEAR);
    lcd_goto(1,1); printf(lcd_out, "rx:%s", rx);
    lcd_goto(2,1); printf(lcd_out, "snd:%s sl:%d", sender, slot);
    delay_ms(3000);

    if(slot < 2 || slot > 5) {
      sprintf(reply,"Invalid slot! Use 2-5 only");
        send_sms_to_number(num1,reply);
        return;
    }

    if(rx[1] == 'E') {
      disable_interrupts(int_AD);
         disable_interrupts(int_TIMER1);
        save_slot_enable_status(slot, 1);
        sprintf(reply, "Slot %d Enabled", slot);
        send_sms_to_number(num1, reply);
          enable_interrupts(int_AD);
         enable_interrupts(int_TIMER1);
         enable_interrupts(GLOBAL);
    }
    else if(rx[1] == 'D') {
      disable_interrupts(int_AD);
         disable_interrupts(int_TIMER1);
        save_slot_enable_status(slot, 0);
        sprintf(reply, "Slot %d Disabled", slot);
        send_sms_to_number(num1, reply);
          enable_interrupts(int_AD);
         enable_interrupts(int_TIMER1);
         enable_interrupts(GLOBAL);
    }
}
void read_number(int slot, char *num) {
   int base_addr;
   if(slot==1) base_addr=NUM1_ADDR;
   else if(slot==2) base_addr=NUM2_ADDR;
   else if(slot==3) base_addr=NUM3_ADDR;
   else if(slot==4) base_addr=NUM4_ADDR;
   else if(slot==5) base_addr=NUM5_ADDR;
   else return;

   for(int i=0;i<10;i++)
      num[i]=read_eeprom(base_addr+i);
   num[10]='\0';
}

void send_sms_to_all_enabled(char *msg) {
    for(int slot = 1; slot <= 5; slot++) {
        // Skip if slot is disabled
        if(slot_enabled[slot] == 0) {
            continue;
        }
       
        read_number(slot, number);
        if(number[0] != '\0' && number[0] != 0xFF) {
               disable_interrupts(int_AD);
            disable_interrupts(int_TIMER1);
            send_sms_to_number(number, msg);
              enable_interrupts(int_AD);
                  enable_interrupts(int_TIMER1);
                  enable_interrupts(GLOBAL);
        }
    }
}
