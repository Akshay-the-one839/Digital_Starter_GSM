/*----------------------------------------------------------------------------
 * gsm_init : Send AT initialisation commands to SIM800L
 *            Called once after gsm_enable flag is confirmed set
 *---------------------------------------------------------------------------*/
void gsm_init(void)
{
   lcd_cmd(LCD_CLEAR);
   lcd_goto(1,1); printf(lcd_out,"GSM INIT...");
   lcd_goto(1,2); printf(lcd_out,"Please wait");

   // Allow modem to stabilise
   delay_ms(3000);
   delay_ms(3000);
   delay_ms(3000);
   delay_ms(3000);
   delay_ms(3000);

   fprintf(GSM, "AT\r");           delay_ms(1000);
   fprintf(GSM, "AT\r");           delay_ms(1000);
   fprintf(GSM, "AT+CMGF=1\r");   delay_ms(1000); // SMS text mode
   fprintf(GSM, "AT+CNMI=2,2,0,0,0\r"); delay_ms(1000); // push new SMS to UART

   // Delete all stored SMS to keep SIM memory clean
   fprintf(GSM, "AT+CMGD=1,4\r"); delay_ms(3000);

   lcd_cmd(LCD_CLEAR);
   lcd_goto(1,1); printf(lcd_out,"GSM READY");
  // lcd_goto(1,2); printf(lcd_out,"SIM800L OK");
   delay_ms(1500);



   lcd_cmd(LCD_CLEAR);
}

