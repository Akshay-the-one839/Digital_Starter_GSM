      { delay_ms(5); if(ir_10min_int<1000)ir_10min_int+=5; delay_ms(40); while(input(ENCODER_A)==0); }
      else if(input(ENCODER_B)==0&&input(ENCODER_A)!=0)
      { delay_ms(5); if(ir_10min_int>5)ir_10min_int-=5; delay_ms(40); while(input(ENCODER_B)==0); }
      if(input(ENCODER_SW)==0)
      {
         delay_ms(50); button_pressed_flag=1;
         if(ir_10min_int!=original_ir_10min) values_changed=1;
         if(values_changed||(ir_1min_int!=original_ir_1min)||(ir_10min_int!=original_ir_10min))
         {
            lcd_cmd(LCD_CLEAR); lcd_goto(1,1); printf(lcd_out,"PI VALUES SAVED!");
            lcd_goto(1,2); printf(lcd_out,"1m:%3.1f 10m:%3.1f",ir_1min,ir_10min);
