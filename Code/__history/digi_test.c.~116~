   int16 last_value=-1;
   int1 button_pressed_flag=0, values_changed=0;

   lcd_cmd(LCD_CLEAR); delay_ms(100);
   lcd_goto(1,1); printf(lcd_out,"15.PI TEST-IR@1m");

   while(1)
   {
      ir_1min=(float)ir_1min_int/10.0;
