void check_unbalance_trip()
{
   float r=(float)ramp, y=(float)yamp, b=(float)bamp;
   float mx=r; if(y>mx)mx=y; if(b>mx)mx=b;
   float mn=r; if(y<mn)mn=y; if(b<mn)mn=b;
   float avg=(r+y+b)/3.0;
   if(avg==0.0){ trip_status=0; return; }
   float unbalance=((mx-mn)/avg)*100.0;
   int16 ub_limit=make16(read_eeprom(0x27),read_eeprom(0x26));
   if(ub_limit>100) ub_limit=30;
   if(unbalance>ub_limit){ output_low(PIN_C1); trip_status=1; }
   else trip_status=0;
}

