         }
         else { while(input(ENCODER_SW)==0) delay_ms(10); }
         break;
      }
      delay_ms(1);
   }

   last_value=-1;
   lcd_cmd(LCD_CLEAR); delay_ms(50);
   lcd_goto(1,1); printf(lcd_out,"Enter IR@10min  ");

   while(1)
   {
      ir_10min=(float)ir_10min_int/10.0;
