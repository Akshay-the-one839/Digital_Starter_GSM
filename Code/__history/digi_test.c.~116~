//==============================================================================
// GSM MENU  (menu item 14)
// First screen: ENABLE / DISABLE toggle
// If ENABLED: sub-menu for number management
//==============================================================================

/*----------------------------------------------------------------------------
 * handle_gsm_menu  (called from handle_menu as menu item 14)
 *---------------------------------------------------------------------------*/
void handle_gsm_menu(void)
{
   while(input(ENCODER_SW)==0);

   int8 gsm_sel = gsm_enable;
   if(gsm_sel!=0 && gsm_sel!=1) gsm_sel=0;
   int8 last_gsm=255;

   lcd_cmd(LCD_CLEAR);
   lcd_goto(1,1); printf(lcd_out,"14.GSM SETTING");
   lcd_goto(1,2);
   if(gsm_sel==1) printf(lcd_out,">> ENABLE        ");
   else            printf(lcd_out,">> DISABLE       ");

   while(1)
   {
      if(input(ENCODER_A)==0&&input(ENCODER_B)!=0)
      { delay_ms(5); gsm_sel=(gsm_sel==1)?0:1; while(input(ENCODER_A)==0); }
      else if(input(ENCODER_B)==0&&input(ENCODER_A)!=0)
      { delay_ms(5); gsm_sel=(gsm_sel==1)?0:1; while(input(ENCODER_B)==0); }

      if(gsm_sel!=last_gsm)
      {
         lcd_goto(1,2);
         if(gsm_sel==1) printf(lcd_out,">> ENABLE        ");
         else            printf(lcd_out,">> DISABLE       ");
         last_gsm=gsm_sel;
      }

      if(input(ENCODER_SW)==0)
      {
         delay_ms(20);
         if(input(ENCODER_SW)==0)
         {
            while(input(ENCODER_SW)==0);

            // Save new state to EEPROM
            write_eeprom(GSM_ENABLE_ADDR, gsm_sel);
            gsm_enable = gsm_sel;

            lcd_cmd(LCD_CLEAR); lcd_goto(1,1); printf(lcd_out,"GSM SAVED");
            lcd_goto(1,2);
            if(gsm_enable==1) printf(lcd_out,"STATUS: ENABLE  ");
            else               printf(lcd_out,"STATUS: DISABLE ");
            delay_ms(1200);

            // Handle interrupt enabling/disabling based on new state
            if(gsm_enable==1)
            {
               // Just enable the RDA interrupt - GSM already initialized from main
               enable_interrupts(INT_RDA);
               lcd_cmd(LCD_CLEAR); lcd_goto(1,1); printf(lcd_out,"GSM ENABLED");
               lcd_goto(1,2); printf(lcd_out,"RESTART DEVICE");
               delay_ms(1000);
            }
            else
            {
               // GSM disabled - disable RDA interrupt to stop receiving GSM data
               disable_interrupts(INT_RDA);
               lcd_cmd(LCD_CLEAR); lcd_goto(1,1); printf(lcd_out,"GSM DISABLED");
               delay_ms(1000);
            }

            lcd_cmd(LCD_CLEAR);
            advance_to_next_menu();
            break;
         }
      }
      delay_ms(1);
   }
}
