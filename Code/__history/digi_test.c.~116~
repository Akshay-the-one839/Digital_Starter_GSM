      { delay_ms(5); if(ir_1min_int<1000)ir_1min_int+=5; delay_ms(40); while(input(ENCODER_A)==0); }
      else if(input(ENCODER_B)==0&&input(ENCODER_A)!=0)
      { delay_ms(5); if(ir_1min_int>5)ir_1min_int-=5; delay_ms(40); while(input(ENCODER_B)==0); }
      if(input(ENCODER_SW)==0)
      {
         delay_ms(50); button_pressed_flag=1;
         if(ir_1min_int!=original_ir_1min)
         {
            values_changed=1;
            lcd_cmd(LCD_CLEAR); lcd_goto(1,1); printf(lcd_out,"IR@1m SAVED!");
