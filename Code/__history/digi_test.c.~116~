void handle_polarization_index_menu(void)
{
   while(input(ENCODER_SW)==0);
   int16 ir_1min_int =make16(read_eeprom(0x3B),read_eeprom(0x3A));
   int16 ir_10min_int=make16(read_eeprom(0x3D),read_eeprom(0x3C));
