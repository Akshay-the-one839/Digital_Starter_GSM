void load_next_timer_slot(void)
{
   int8 attempts = 0;
   int8 on_h, on_m, off_h, off_m;

   while(attempts < 5)
   {
      int8 base = 0x20 + (active_timer_slot * 4);
      on_h  = read_eeprom(base + 0);
      on_m  = read_eeprom(base + 1);
      off_h = read_eeprom(base + 2);
      off_m = read_eeprom(base + 3);

      if(on_h  > 23) on_h  = 0;
      if(on_m  > 59) on_m  = 0;
      if(off_h > 23) off_h = 0;
      if(off_m > 59) off_m = 0;

      // Skip if all zero
      if(on_h==0 && on_m==0 && off_h==0 && off_m==0)
      {
         active_timer_slot = (active_timer_slot + 1) % 5;
         attempts++;
         continue;
      }

      // Valid slot found - load ON phase countdown
      timer_phase = 0;
      timer_h = on_h;
      timer_m = on_m;
      timer_s = 0;
      timer_phase_done = 0;
      timer_running = 1;

      // Turn motor ON
      disable_interrupts(int_AD);
      disable_interrupts(int_TIMER1);
      if(volt_level==0 && amps_level==0)
      {
        ctimer=1;
         mon();
         on_state = 1;
         state = 1;
         q = 'A';
         if(gsm_enable==1)
         {
          disable_interrupts(int_AD);
         disable_interrupts(int_TIMER1);
            strcpy(msg_buffer, LED_ON_MSG);
            send_sms_to_all_enabled(msg_buffer);
         }
      }
      enable_interrupts(int_AD);
      enable_interrupts(int_TIMER1);
      enable_interrupts(GLOBAL);

     /* lcd_cmd(LCD_CLEAR);
      lcd_goto(1,1); printf(lcd_out,"TIMER %d ON", active_timer_slot+1);
      lcd_goto(1,2); printf(lcd_out,"%02u:%02u ", on_h, on_m);
      delay_ms(1000);
      lcd_cmd(LCD_CLEAR);*/
      return;
   }

   // All 5 slots are zero - fallback to manual
   timer_running = 0;
   timer_mode = 0;
   write_eeprom(TIMER_MODE_ADDR, 0);
   lcd_cmd(LCD_CLEAR);
   lcd_goto(1,1); printf(lcd_out,"NO VALID TIMERS!");
   lcd_goto(1,2); printf(lcd_out,"Switched:MANUAL ");
   delay_ms(2000);
   lcd_cmd(LCD_CLEAR);
}
void handle_timer_mode(void)
{
   // First entry - initialise
  if(timer_running == 0)
{
   if(timer_phase_done == 0)
   {
      active_timer_slot = 0;
      load_next_timer_slot();
   }
   return;
}

   // Check if current phase countdown finished
   if(timer_phase_done == 1)
   {
      timer_phase_done = 0;
      timer_running = 0;

      if(timer_phase == 0)
      {
         // ON phase done - load OFF phase
         int8 base = 0x20 + (active_timer_slot * 4);
         int8 off_h = read_eeprom(base + 2);
         int8 off_m = read_eeprom(base + 3);
         if(off_h > 23) off_h = 0;
         if(off_m > 59) off_m = 0;

         timer_phase = 1;
         timer_h = off_h;
         timer_m = off_m;
         timer_s = 0;
         timer_phase_done = 0;
         timer_running = 1;

         // Turn motor OFF
         disable_interrupts(int_AD);
         disable_interrupts(int_TIMER1);
          ctimer=0;
         moff();
         on_state = 0;
         state = 0;
         q = 'a';
         if(gsm_enable==1)
         {
            strcpy(msg_buffer, LED_OFF_MSG);
            send_sms_to_all_enabled(msg_buffer);
         }
         enable_interrupts(int_AD);
         enable_interrupts(int_TIMER1);
         enable_interrupts(GLOBAL);

     /*    lcd_cmd(LCD_CLEAR);
         lcd_goto(1,1); printf(lcd_out,"TIMER %d OFF", active_timer_slot+1);
         lcd_goto(1,2); printf(lcd_out,"%02u:%02u ", off_h, off_m);
         delay_ms(1000);
         lcd_cmd(LCD_CLEAR);*/
      }
      else
      {
         // OFF phase done - move to next slot and cycle
         active_timer_slot = (active_timer_slot + 1) % 5;
         load_next_timer_slot();
      }
   }
}
